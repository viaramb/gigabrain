# Path to the Gigabrain SQLite registry database
GB_REGISTRY_PATH=/path/to/memory.db

# Directory for document store files (optional)
# GB_DOCS_PATH=/path/to/docs

# Agent ID for document indexing (optional, default: shared-docs)
# GB_DOC_INDEX_AGENT=shared-docs

# Auth token — required, all API requests must include X-GB-Token header
GB_UI_TOKEN=changeme
